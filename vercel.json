{
  "version": 2,
  "builds": [
    {
      "src": "UrbanEats/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "adminpanel/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/admin/(.*)",
      "dest": "/adminpanel/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/UrbanEats/$1"
    }
  ]
}
